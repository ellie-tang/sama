<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/root_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="0dp"
    android:fitsSystemWindows="false"
    tools:context=".center_content_template_activity">

    <!-- Welcome banner for AI Assistant - floating text effect -->
    <TextView
        android:id="@+id/welcome_banner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Welcome to SAMA"
        android:textSize="29sp"
        android:textStyle="bold"
        android:gravity="center"
        android:padding="16dp"
        android:textColor="@color/hud_white"
        android:layout_alignParentTop="true"
        android:layout_alignParentStart="true"
        android:layout_alignParentEnd="true"/>

    <!-- Thumbnail image view on left/middle side -->
    <ImageView
        android:id="@+id/thumbnail_image"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:layout_centerVertical="true"
        android:layout_alignParentStart="true"
        android:layout_marginStart="20dp"
        android:scaleType="centerCrop"
        android:background="#40FFFFFF"
        android:padding="2dp"
        android:visibility="gone"/>

    <!-- Status banner at bottom of screen - floating text effect -->
    <TextView
        android:id="@+id/status_message"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="System Ready"
        android:textSize="26sp"
        android:textStyle="bold"
        android:gravity="center"
        android:padding="12dp"
        android:textColor="@color/hud_white"
        android:layout_alignParentBottom="true"
        android:layout_alignParentStart="true"
        android:layout_alignParentEnd="true"/>

</RelativeLayout>
